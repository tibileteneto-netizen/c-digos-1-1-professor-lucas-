-- Consultando Times com seus Campeonatos (JOIN triplo)
SELECT 
    t.nome AS time,
    c.nome_campeonato AS campeonato,
    tc.ano_temporada
FROM Times t
INNER JOIN Times_Campeonatos tc ON t.id = tc.time_id
INNER JOIN Campeonatos c ON tc.campeonato_id = c.id
ORDER BY t.nome, c.nome_campeonato;

-- Consultando Campeonatos com seus Times (visão inversa)
SELECT 
    c.nome_campeonato AS campeonato,
    t.nome AS time,
    tc.ano_temporada
FROM Campeonatos c
INNER JOIN Times_Campeonatos tc ON c.id = tc.campeonato_id
INNER JOIN Times t ON tc.time_id = t.id
ORDER BY c.nome_campeonato, t.nome;
