-- Criando a tabela de Times (se ainda não existir)
CREATE TABLE Times (
    id INT PRIMARY KEY,
    nome VARCHAR(100) NOT NULL
);

-- Criando a tabela de Campeonatos
CREATE TABLE Campeonatos (
    id INT PRIMARY KEY,
    nome_campeonato VARCHAR(100) NOT NULL
);

-- Criando a Tabela Pivô (resolve a relação N-N)
CREATE TABLE Times_Campeonatos (
    time_id INT NOT NULL,
    campeonato_id INT NOT NULL,
    ano_temporada INT,
    PRIMARY KEY (time_id, campeonato_id, ano_temporada),  -- Chave composta
    FOREIGN KEY (time_id) REFERENCES Times(id),
    FOREIGN KEY (campeonato_id) REFERENCES Campeonatos(id)
);

