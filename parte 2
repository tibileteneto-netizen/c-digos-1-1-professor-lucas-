-- Criando a tabela de Times (se ainda não existir)
CREATE TABLE Times (
    id INT PRIMARY KEY,
    nome VARCHAR(100) NOT NULL,
    cidade VARCHAR(100),
    ano_fundacao INT
);

-- Criando a tabela de Jogadores (relação 1-N)
CREATE TABLE Jogadores (
    id INT PRIMARY KEY,
    time_id INT NOT NULL,
    nome_jogador VARCHAR(100),
    posicao VARCHAR(50),
    numero_camisa INT,
    FOREIGN KEY (time_id) REFERENCES Times(id)
);

