-- Consultando Times com seus Jogadores (JOIN)
SELECT 
    t.nome AS time,
    j.nome_jogador,
    j.posicao,
    j.numero_camisa
FROM Times t
INNER JOIN Jogadores j ON t.id = j.time_id
ORDER BY t.nome, j.nome_jogador;
