-- Criando a tabela de Times
CREATE TABLE Times (
    id INT PRIMARY KEY,
    nome VARCHAR(100) NOT NULL,
    cidade VARCHAR(100),
    ano_fundacao INT
);

-- Criando a tabela de Estádios (relação 1-1)
CREATE TABLE Estadios (
    id INT PRIMARY KEY,
    time_id INT UNIQUE NOT NULL,  -- UNIQUE garante que cada time tenha apenas 1 estádio
    nome_estadio VARCHAR(100),
    capacidade INT,
    FOREIGN KEY (time_id) REFERENCES Times(id)
);

