-- Consultando Times com seus Estádios (JOIN)
SELECT 
    t.nome AS time,
    t.cidade,
    e.nome_estadio AS estadio,
    e.capacidade
FROM Times t
INNER JOIN Estadios e ON t.id = e.time_id;
